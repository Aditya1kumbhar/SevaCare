// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String   @unique
  password  String
  role      UserRole @default(CARETAKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  residents     Resident[]
  deviceTokens  DeviceToken[]

  @@map("users")
}

enum UserRole {
  ADMIN
  CARETAKER
  SUPERVISOR
}

model Resident {
  id                      String   @id @default(cuid())
  name                    String
  age                     Int
  gender                  String   // Male, Female, Other
  chronicIllnesses        String[] // Array of illness names
  mobilityStatus          String   // Uses Walker, Wheelchair, Independent, Bedridden
  memoryLoss              Boolean  @default(false)
  anxietyDepression       Boolean  @default(false)
  allergies               String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  medications      Medication[]
  healthRecords    HealthRecord[]
  medicineScans    MedicineScan[]
  activityLogs     ActivityLog[]

  @@index([userId])
  @@map("residents")
}

model Medication {
  id        String   @id @default(cuid())
  name      String
  dose      String
  frequency String   // Once daily, Twice daily, As needed
  time      String   // Time of administration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@map("medications")
}

model HealthRecord {
  id           String   @id @default(cuid())
  dateRecorded DateTime @default(now())
  bloodPressure String?
  heartRate     Int?
  temperature   Float?
  weight        Float?
  notes         String?
  recordedBy    String   // Name of person who recorded
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@map("health_records")
}

model MedicineScan {
  id              String   @id @default(cuid())
  medicineNameEn  String
  medicineNameMr  String
  usageEn         String
  usageMr         String
  scannedAt       DateTime @default(now())
  isAdded         Boolean  @default(false) // Whether added to resident profile
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@map("medicine_scans")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // "added_resident", "updated_resident", "downloaded_report", etc
  details   String?
  createdAt DateTime @default(now())

  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@map("activity_logs")
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

