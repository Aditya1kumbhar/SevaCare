# Database Configuration
# PostgreSQL Local: postgresql://user:password@localhost:5432/database_name
# Prisma Postgres Free: Get from https://www.prisma.io/cloud/
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sevacare_db"

# Server Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_key_here_change_in_production_to_random_string_32_chars_minimum
JWT_EXPIRATION=24h

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Optional: Database logging
# DATABASE_LOG_LEVEL=info
