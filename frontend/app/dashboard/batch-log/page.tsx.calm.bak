'use client'

import { useState, useEffect, useCallback } from 'react'
import { createClient } from '@/lib/supabase/client'
import { toast } from 'sonner'
import { Pill, Utensils, Save, Phone, RefreshCw, CheckCircle2, XCircle, AlertCircle } from 'lucide-react'

type ResidentRow = {
  id: string
  name: string
  family_phone_number: string
  family_contact_name: string
  meds: '' | 'taken' | 'refused'
  meal: '' | 'full' | 'half' | 'skipped'
  saved: boolean
  saving: boolean
  whatsappOpened: boolean
}

export default function BatchLogPage() {
  const [rows, setRows] = useState<ResidentRow[]>([])
  const [loading, setLoading] = useState(true)
  const supabase = createClient()

  useEffect(() => {
    async function load() {
      const { data } = await supabase.from('residents').select('id, name, family_phone_number, family_contact_name').order('name')
      if (data) {
        setRows(data.map(r => ({ ...r, meds: '', meal: '', saved: false, saving: false, whatsappOpened: false })))
      }
      setLoading(false)
    }
    load()
  }, [])

  const toggle = useCallback((id: string, field: 'meds' | 'meal', value: string) => {
    setRows(prev => prev.map(r => r.id === id ? { ...r, [field]: r[field] === value ? '' : value } : r))
  }, [])

  async function saveAndWhatsApp(row: ResidentRow) {
    if (!row.meds && !row.meal) { toast.error('Select at least meds or meal'); return }

    // Mark saving
    setRows(prev => prev.map(r => r.id === row.id ? { ...r, saving: true } : r))

    const { data: { user } } = await supabase.auth.getUser()
    if (!user) { toast.error('Not logged in'); setRows(prev => prev.map(r => r.id === row.id ? { ...r, saving: false } : r)); return }

    const status = row.meds === 'refused' || row.meal === 'skipped' ? 'poor' : 'good'

    const { error } = await supabase.from('daily_logs').insert({
      resident_id: row.id,
      caretaker_id: user.id,
      status,
      meal_taken: row.meal === 'full' || row.meal === 'half',
      medication_taken: row.meds === 'taken',
      whatsapp_sent: true,
    })

    if (error) {
      toast.error(error.message)
      setRows(prev => prev.map(r => r.id === row.id ? { ...r, saving: false } : r))
      return
    }

    setRows(prev => prev.map(r => r.id === row.id ? { ...r, saved: true, saving: false } : r))
    toast.success(`${row.name} saved`)

    const phone = row.family_phone_number.replace(/[^0-9]/g, '')
    const now = new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })
    const mealText: Record<string, string> = { full: 'Full meal', half: 'Half meal', skipped: 'Skipped' }
    const medText: Record<string, string> = { taken: 'Taken', refused: 'Refused' }

    let msg = `SEVACARE UPDATE\nPATIENT: ${row.name}\n`
    if (row.meds) msg += `MEDS: ${medText[row.meds]}\n`
    if (row.meal) msg += `MEAL: ${mealText[row.meal]}\n`
    msg += `TIME: ${now}`

    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`, '_blank')
    setRows(prev => prev.map(r => r.id === row.id ? { ...r, whatsappOpened: true } : r))
  }

  const cleared = rows.filter(r => r.saved).length
  const total = rows.length
  const allCleared = total > 0 && cleared === total

  if (loading) return <p className="text-[#878787] text-center py-16 text-lg font-mono uppercase tracking-widest">LOADING DIRECTORY...</p>
  if (rows.length === 0) return <p className="text-[#878787] text-center py-16 text-lg font-mono uppercase tracking-widest">NO RESIDENTS FOUND in database.</p>

  return (
    <div className="space-y-4 max-w-2xl mx-auto pb-8 bg-[#f1f3f6] min-h-screen p-4">
      {/* Header */}
      <div className="sticky top-0 z-10 bg-[#f1f3f6] border-b border-[#e0e0e0] pb-4 mb-6">
        <div className="flex items-center justify-between mb-2">
          <h2 className="text-xl font-bold text-[#212121] uppercase tracking-widest flex items-center gap-2">
            <RefreshCw className="w-5 h-5 text-[#212121]" /> BATCH PROTOCOL
          </h2>
          <span className={`text-sm font-bold font-mono px-3 py-1 ${allCleared ? 'bg-green-600 text-[#212121]' : 'bg-[#ff6161] text-white'}`}>
            {cleared}/{total} SECURE
          </span>
        </div>
      </div>

      {/* All clear celebration */}
      {allCleared && (
        <div className="p-6 bg-[#f1f3f6] border-2 border-green-600">
          <div className="flex items-center gap-4 mb-4">
            <CheckCircle2 className="w-8 h-8 text-green-500" />
            <p className="text-xl text-green-500 font-bold uppercase tracking-widest">SHIFT CLEARANCE APPROVED</p>
          </div>
          <button
            onClick={() => setRows(prev => prev.map(r => ({ ...r, saved: false, saving: false, whatsappOpened: false, meds: '', meal: '' })))}
            className="w-full py-4 bg-zinc-800 hover:bg-zinc-700 text-[#212121] font-bold tracking-widest uppercase flex items-center justify-center gap-2 transition-none"
          >
            <RefreshCw className="w-4 h-4" /> RE-INITIALIZE PROTOCOL
          </button>
        </div>
      )}

      {/* Resident Rows */}
      {rows.map((r) => (
        <div
          key={r.id}
          className={`border-2 p-5 bg-[#f1f3f6] transition-none mb-4 ${
            r.saved
              ? 'border-green-600 opacity-60'
              : r.saving
                ? 'border-yellow-500'
                : 'border-[#e0e0e0]'
          }`}
        >
          {/* Row 1: Name + Status icon */}
          <div className="flex items-start justify-between mb-6 border-b border-[#e0e0e0] pb-3">
            <div>
              <h3 className="text-xl font-bold text-[#212121] uppercase tracking-wider">{r.name}</h3>
              <p className="text-sm text-[#878787] font-mono mt-1">ID: {r.id.split('-')[0].toUpperCase()} | EXT: {r.family_phone_number}</p>
            </div>
            {r.saved ? (
              <CheckCircle2 className="w-6 h-6 text-green-500" />
            ) : (
              <AlertCircle className="w-6 h-6 text-[#ff6161]" />
            )}
          </div>

          {r.saved ? (
            /* Locked saved state */
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-4 text-sm font-bold uppercase tracking-widest text-green-500">
                <span>VERIFIED</span>
                {r.meds && <span className="px-2 py-1 bg-green-900 border border-green-500 text-green-400 font-mono">MD:{r.meds.substring(0,3).toUpperCase()}</span>}
                {r.meal && <span className="px-2 py-1 bg-green-900 border border-green-500 text-green-400 font-mono">ML:{r.meal.substring(0,3).toUpperCase()}</span>}
              </div>
              {r.whatsappOpened && <span className="text-xs text-green-600 font-bold tracking-widest uppercase flex items-center gap-1"><Phone className="w-3 h-3"/> TRANSMITTED</span>}
            </div>
          ) : (
            <>
              {/* Row 2: Meds toggle */}
              <div className="mb-6">
                <div className="flex items-center gap-2 mb-3">
                  <Pill className="w-4 h-4 text-[#878787]" />
                  <p className="text-sm font-bold text-[#878787] uppercase tracking-widest">CLINICAL: MEDICATION</p>
                </div>
                <div className="grid grid-cols-2 gap-px bg-zinc-800 border border-[#e0e0e0]">
                  <button
                    type="button"
                    onClick={() => toggle(r.id, 'meds', 'taken')}
                    className={`py-4 text-sm font-bold tracking-widest uppercase transition-none ${
                        r.meds === 'taken'
                        ? 'bg-green-600 text-[#212121]'
                        : 'bg-[#f1f3f6] text-[#878787] hover:bg-white'
                    }`}
                  >
                    ADMINISTERED
                  </button>
                  <button
                    type="button"
                    onClick={() => toggle(r.id, 'meds', 'refused')}
                    className={`py-4 text-sm font-bold tracking-widest uppercase transition-none ${
                        r.meds === 'refused'
                        ? 'bg-[#ff6161] text-white'
                        : 'bg-[#f1f3f6] text-[#878787] hover:bg-white'
                    }`}
                  >
                    REFUSED
                  </button>
                </div>
              </div>

              {/* Row 3: Meals toggle */}
              <div className="mb-6">
                <div className="flex items-center gap-2 mb-3">
                  <Utensils className="w-4 h-4 text-[#878787]" />
                  <p className="text-sm font-bold text-[#878787] uppercase tracking-widest">NUTRITIONAL: MEAL INTAKE</p>
                </div>
                <div className="grid grid-cols-3 gap-px bg-zinc-800 border border-[#e0e0e0]">
                  <button
                    type="button"
                    onClick={() => toggle(r.id, 'meal', 'full')}
                    className={`py-4 text-sm font-bold tracking-widest uppercase transition-none ${
                        r.meal === 'full'
                        ? 'bg-green-600 text-[#212121]'
                        : 'bg-[#f1f3f6] text-[#878787] hover:bg-white'
                    }`}
                  >
                    OPTIMAL
                  </button>
                  <button
                    type="button"
                    onClick={() => toggle(r.id, 'meal', 'half')}
                    className={`py-4 text-sm font-bold tracking-widest uppercase transition-none ${
                        r.meal === 'half'
                        ? 'bg-yellow-600 text-[#212121]'
                        : 'bg-[#f1f3f6] text-[#878787] hover:bg-white'
                    }`}
                  >
                    PARTIAL
                  </button>
                  <button
                    type="button"
                    onClick={() => toggle(r.id, 'meal', 'skipped')}
                    className={`py-4 text-sm font-bold tracking-widest uppercase transition-none ${
                        r.meal === 'skipped'
                        ? 'bg-[#ff6161] text-white'
                        : 'bg-[#f1f3f6] text-[#878787] hover:bg-white'
                    }`}
                  >
                    REFUSED
                  </button>
                </div>
              </div>

              {/* Row 4: Save & WhatsApp */}
              <button
                onClick={() => saveAndWhatsApp(r)}
                disabled={r.saving || (!r.meds && !r.meal)}
                className="w-full py-5 text-lg font-bold tracking-widest uppercase flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white disabled:bg-[#e0e0e0] disabled:text-[#878787] disabled:cursor-not-allowed transition-none"
              >
                {r.saving ? (
                  <>PROCESSING TRANSACTION...</>
                ) : (
                  <>
                    <Save className="w-5 h-5" /> COMMIT RECORD & NOTIFY
                  </>
                )}
              </button>
            </>
          )}
        </div>
      ))}
    </div>
  )
}
