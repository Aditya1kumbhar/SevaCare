import { createClient } from '@/lib/supabase/server'
import { redirect } from 'next/navigation'
import Link from 'next/link'
import { Users, ClipboardList, LayoutDashboard, Settings, UserCircle, LogOut, ShieldAlert } from 'lucide-react'

const NAV_ITEMS = [
  { name: 'Dashboard', href: '/dashboard', icon: LayoutDashboard },
  { name: 'Residents', href: '/dashboard/residents', icon: Users },
  { name: 'Batch Log', href: '/dashboard/batch-log', icon: ClipboardList },
  { name: 'System Config', href: '/dashboard/admin', icon: Settings },
]

export default async function DashboardLayout({
  children,
}: {
  children: React.ReactNode
}) {
  const supabase = await createClient()
  const { data: { user } } = await supabase.auth.getUser()

  async function handleSignOut() {
    'use server'
    const supabase = await createClient()
    await supabase.auth.signOut()
    redirect('/')
  }

  if (!user) redirect('/')

  return (
    <div className="min-h-screen bg-zinc-950 flex">
      {/* Sidebar */}
      <aside className="w-56 bg-zinc-900 border-r border-zinc-800 flex flex-col shrink-0">
        <div className="p-4 border-b border-zinc-800 flex items-center gap-2">
          <ShieldAlert className="w-5 h-5 text-white" />
          <div>
            <h1 className="text-lg font-bold text-white tracking-widest uppercase">SEVACARE</h1>
            <p className="text-[10px] text-zinc-500 mt-1 font-mono uppercase truncate">{user.email}</p>
          </div>
        </div>
        <nav className="flex-1 px-4 py-6 space-y-2">
          {NAV_ITEMS.map((item) => (
            <Link
              key={item.href}
              href={item.href}
              className="flex items-center gap-4 px-4 py-4 text-sm font-bold uppercase tracking-widest text-zinc-400 hover:bg-zinc-900 hover:text-white transition-none"
            >
              <item.icon className="w-5 h-5" />
              {item.name}
            </Link>
          ))}
        </nav>
        <div className="p-0 border-t border-zinc-800">
          <form action="/api/auth/signout" method="POST">
            <button
              type="submit"
              className="w-full px-4 py-4 text-[10px] font-bold tracking-widest uppercase text-zinc-500 hover:text-red-500 hover:bg-zinc-900 border-none transition-none text-left flex items-center gap-2"
            >
              <LogOut className="w-4 h-4" /> TERMINATE SESSION
            </button>
          </form>
        </div>
      </aside>

      {/* Main content */}
      <main className="flex-1 p-6 overflow-auto">
        <div className="max-w-5xl mx-auto">{children}</div>
      </main>
    </div>
  )
}
