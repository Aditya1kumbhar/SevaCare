import { createClient } from '@/lib/supabase/server'
import Link from 'next/link'
import { PlusSquare, ClipboardList, Phone, AlertTriangle, ShieldAlert } from 'lucide-react'

export default async function ResidentsPage() {
  const supabase = await createClient()
  const { data: residents } = await supabase.from('residents').select('*').order('name')

  return (
    <div className="space-y-6 bg-black min-h-screen">
      <div className="flex items-center justify-between border-b-2 border-zinc-900 pb-4">
        <h2 className="text-2xl font-bold tracking-widest uppercase text-white">RESIDENT DIRECTORY</h2>
        <Link 
          href="/dashboard/residents/add" 
          className="flex items-center gap-2 px-5 py-3 text-sm font-bold tracking-widest uppercase bg-zinc-900 hover:bg-zinc-800 text-white transition-none border-2 border-zinc-800 hover:border-zinc-600"
        >
          <PlusSquare className="w-4 h-4" /> ADD ENTRY
        </Link>
      </div>

      {!residents || residents.length === 0 ? (
        <div className="text-center py-16 border-2 border-zinc-900 border-dashed">
          <p className="text-zinc-500 text-sm font-mono uppercase tracking-widest">DIRECTORY EMPTY.</p>
        </div>
      ) : (
        <div className="space-y-0 border-2 border-zinc-900 border-b-0">
          {residents.map((r, i) => (
            <div key={r.id} className="bg-black border-b-2 border-zinc-900 p-5 hover:bg-zinc-900/40 transition-none group">
              <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <Link href={`/dashboard/residents/${r.id}`} className="flex-1">
                  <div className="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                    <h3 className="text-xl font-bold tracking-widest uppercase text-white group-hover:text-blue-400 transition-none">{r.name}</h3>
                    <div className="flex flex-wrap gap-2">
                      {r.wandering_risk && <span className="flex items-center gap-1 bg-red-950 text-red-500 text-[10px] px-2 py-0.5 font-bold uppercase tracking-widest border border-red-900"><ShieldAlert className="w-3 h-3" /> ELOPEMENT</span>}
                      {r.aggression_triggers && <span className="flex items-center gap-1 bg-yellow-950 text-yellow-500 text-[10px] px-2 py-0.5 font-bold uppercase tracking-widest border border-yellow-900"><AlertTriangle className="w-3 h-3" /> AGGRESSION</span>}
                      {r.life_threatening_allergies && r.life_threatening_allergies !== 'None' && <span className="flex items-center gap-1 bg-orange-950 text-orange-500 text-[10px] px-2 py-0.5 font-bold uppercase tracking-widest border border-orange-900"><AlertTriangle className="w-3 h-3" /> ALLERGY</span>}
                    </div>
                  </div>
                  <div className="flex flex-wrap items-center gap-3 text-xs font-mono text-zinc-500">
                    <span className="border-r border-zinc-800 pr-3">AGE: {r.age}</span>
                    {r.room_number && <span className="border-r border-zinc-800 pr-3">RM: {r.room_number}</span>}
                    {r.mobility_status && <span className="border-r border-zinc-800 pr-3">MOBILITY: {r.mobility_status.toUpperCase()}</span>}
                    <span className="flex items-center gap-1"><Phone className="w-3 h-3" /> EXT: {r.family_phone_number}</span>
                  </div>
                </Link>
                <Link 
                  href={`/dashboard/log/${r.id}`}
                  className="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-4 sm:py-3 text-sm font-bold tracking-widest uppercase bg-blue-600 hover:bg-blue-500 text-white transition-none"
                >
                  <ClipboardList className="w-4 h-4" /> LOG ENTRY
                </Link>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}
