import { createClient } from '@/lib/supabase/server'
import Link from 'next/link'
import { notFound } from 'next/navigation'
import PdfDownloadButton from './PdfDownloadButton'
import { Activity, Edit, ClipboardList, Phone, AlertTriangle, ShieldAlert, Stethoscope, FileText, Pill, Utensils, HeartPulse } from 'lucide-react'

export default async function ResidentDetailPage({ params }: { params: Promise<{ id: string }> }) {
  const { id } = await params
  const supabase = await createClient()

  const { data: resident } = await supabase.from('residents').select('*').eq('id', id).single()
  if (!resident) notFound()

  const { data: recentLogs } = await supabase.from('daily_logs').select('*').eq('resident_id', id).order('logged_at', { ascending: false }).limit(10)
  const { data: healthRecords } = await supabase.from('health_records').select('*').eq('resident_id', id).order('recorded_at', { ascending: false }).limit(5)
  
  const statusColors: Record<string, string> = { 
    good: 'text-green-500 bg-green-950 border-green-500', 
    fair: 'text-yellow-500 bg-yellow-950 border-yellow-500', 
    poor: 'text-orange-500 bg-orange-950 border-orange-500', 
    critical: 'text-red-500 bg-red-950 border-red-500 animate-pulse' 
  }

  return (
    <div className="space-y-6 bg-black min-h-screen">
      {/* Header */}
      <div className="flex items-start justify-between border-b-2 border-zinc-900 pb-6">
        <div>
          <h2 className="text-3xl font-bold tracking-widest uppercase text-white">{resident.name}</h2>
          <div className="flex flex-wrap items-center gap-3 text-xs font-mono text-zinc-500 mt-2">
            <span className="border-r border-zinc-800 pr-3">AGE: {resident.age}</span>
            {resident.room_number && <span className="border-r border-zinc-800 pr-3">RM: {resident.room_number}</span>}
            {resident.blood_group && <span className="border-r border-zinc-800 pr-3">BLD: {resident.blood_group}</span>}
            <span className="flex items-center gap-1 text-zinc-400"><Phone className="w-3 h-3" /> EXT: {resident.family_phone_number}</span>
          </div>

          <div className="mt-4 space-y-2">
            {resident.life_threatening_allergies && resident.life_threatening_allergies !== 'None' && (
              <p className="text-xs font-bold tracking-widest uppercase text-orange-500 bg-orange-950/20 border-l-2 border-orange-500 pl-2 py-1">
                ALLERGY: {resident.life_threatening_allergies}
              </p>
            )}
            {resident.critical_conditions?.length > 0 && resident.critical_conditions[0] !== 'None' && (
              <p className="text-xs font-bold tracking-widest uppercase text-red-500 bg-red-950/20 border-l-2 border-red-500 pl-2 py-1">
                CONDITIONS: {resident.critical_conditions.join(', ')}
              </p>
            )}
            {resident.aggression_triggers && (
              <p className="text-xs font-bold tracking-widest uppercase text-yellow-500 bg-yellow-950/20 border-l-2 border-yellow-500 pl-2 py-1">
                TRIGGERS: {resident.aggression_triggers}
              </p>
            )}
          </div>

          <div className="flex gap-2 mt-4 flex-wrap">
            {resident.mobility_status && <span className="bg-blue-900 text-blue-100 text-[10px] px-2 py-1 font-bold uppercase tracking-widest">MOBILITY: {resident.mobility_status}</span>}
            {resident.wandering_risk && <span className="flex items-center gap-1 bg-red-950 text-red-500 text-[10px] px-2 py-1 font-bold uppercase tracking-widest border border-red-900"><ShieldAlert className="w-3 h-3" /> ELOPEMENT RISK</span>}
            {resident.aggression_triggers && <span className="flex items-center gap-1 bg-yellow-950 text-yellow-500 text-[10px] px-2 py-1 font-bold uppercase tracking-widest border border-yellow-900"><AlertTriangle className="w-3 h-3" /> AGGRESSION RISK</span>}
            {resident.communication_barrier && resident.communication_barrier !== 'Clear' && <span className="bg-zinc-800 text-zinc-300 text-[10px] px-2 py-1 font-bold uppercase tracking-widest">COMM: {resident.communication_barrier}</span>}
          </div>
        </div>
        <div className="flex gap-0 border-2 border-zinc-900">
          <Link href={`/dashboard/residents/${resident.id}/edit`} className="flex flex-col items-center justify-center p-4 bg-zinc-950 hover:bg-zinc-900 text-zinc-400 border-r border-zinc-900 transition-none group">
            <Edit className="w-5 h-5 mb-1 group-hover:text-blue-400" />
            <span className="text-[10px] font-bold tracking-widest uppercase">EDIT</span>
          </Link>
          <div className="border-r border-zinc-900 flex">
             <PdfDownloadButton resident={resident} healthRecords={healthRecords || []} logs={recentLogs || []} />
          </div>
          <Link href={`/dashboard/residents/${resident.id}/vitals`} className="flex flex-col items-center justify-center p-4 bg-zinc-950 hover:bg-zinc-900 text-purple-500 border-r border-zinc-900 transition-none">
            <Activity className="w-5 h-5 mb-1" />
            <span className="text-[10px] font-bold tracking-widest uppercase text-zinc-400">VITALS</span>
          </Link>
          <Link href={`/dashboard/log/${resident.id}`} className="flex flex-col items-center justify-center p-4 bg-zinc-950 hover:bg-zinc-900 text-blue-500 transition-none">
            <ClipboardList className="w-5 h-5 mb-1" />
            <span className="text-[10px] font-bold tracking-widest uppercase text-zinc-400">LOG</span>
          </Link>
        </div>
      </div>

      {/* Health Records */}
      <div>
        <h3 className="text-lg font-bold tracking-widest uppercase text-white border-b-2 border-zinc-900 pb-2 mb-4 flex items-center gap-2">
          <HeartPulse className="w-5 h-5 text-purple-500" /> CLINICAL VITALS HISTORY
        </h3>
        {healthRecords && healthRecords.length > 0 ? (
          <div className="border-2 border-zinc-900 border-b-0">
            {healthRecords.map((h: any) => (
              <div key={h.id} className="bg-black border-b-2 border-zinc-900 p-4">
                <p className="text-[10px] font-mono text-zinc-500 mb-3 border-b border-zinc-900 pb-2">
                  RECORDED: {new Date(h.recorded_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }).toUpperCase()}
                </p>
                <div className="grid grid-cols-3 md:grid-cols-6 gap-0">
                  {h.blood_pressure && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">BP</p><p className="text-white text-lg font-mono">{h.blood_pressure}</p></div>}
                  {h.heart_rate && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">HR</p><p className="text-white text-lg font-mono">{h.heart_rate}</p></div>}
                  {h.temperature && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">TEMP</p><p className="text-white text-lg font-mono">{h.temperature}°</p></div>}
                  {h.oxygen_level && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">SPO₂</p><p className="text-white text-lg font-mono">{h.oxygen_level}%</p></div>}
                  {h.blood_sugar && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">GLUCOSE</p><p className="text-white text-lg font-mono">{h.blood_sugar}</p></div>}
                  {h.weight && <div className="border-r border-zinc-900 last:border-r-0 px-2"><p className="text-[10px] font-bold tracking-widest text-zinc-500">WEIGHT</p><p className="text-white text-lg font-mono">{h.weight}KG</p></div>}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p className="text-zinc-500 text-sm font-mono uppercase tracking-widest">NO CLINICAL VITALS ON RECORD.</p>
        )}
      </div>

      {/* Recent Daily Logs */}
      <div>
        <h3 className="text-lg font-bold tracking-widest uppercase text-white border-b-2 border-zinc-900 pb-2 mb-4 flex items-center gap-2">
          <ClipboardList className="w-5 h-5 text-blue-500" /> RECENT STATUS LOGS
        </h3>
        {recentLogs && recentLogs.length > 0 ? (
          <div className="border-2 border-zinc-900 border-b-0">
            {recentLogs.map((log: any) => (
              <div key={log.id} className="bg-black border-b-2 border-zinc-900 p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div className="flex flex-wrap items-center gap-3">
                  <span className={`px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase border ${statusColors[log.status] || 'text-zinc-500 border-zinc-500'}`}>
                    {log.status}
                  </span>
                  <div className="flex gap-2">
                    {log.meal_taken && <span className="flex items-center gap-1 text-[10px] font-bold tracking-widest uppercase text-zinc-400 border border-zinc-800 px-2 py-0.5"><Utensils className="w-3 h-3"/> MEAL</span>}
                    {log.medication_taken && <span className="flex items-center gap-1 text-[10px] font-bold tracking-widest uppercase text-zinc-400 border border-zinc-800 px-2 py-0.5"><Pill className="w-3 h-3"/> MEDS</span>}
                    {log.mood && <span className="text-[10px] font-bold tracking-widest uppercase text-zinc-400 border border-zinc-800 px-2 py-0.5">MOOD: {log.mood}</span>}
                  </div>
                </div>
                <p className="text-[10px] font-mono text-zinc-500">
                  {new Date(log.logged_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }).toUpperCase()}
                </p>
              </div>
            ))}
          </div>
        ) : (
          <p className="text-zinc-500 text-sm font-mono uppercase tracking-widest">NO LOG ENTRIES DETECTED.</p>
        )}
      </div>


    </div>
  )
}
