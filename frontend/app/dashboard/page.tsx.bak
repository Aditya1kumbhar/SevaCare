import { createClient } from '@/lib/supabase/server'
import { Users, ClipboardList, ShieldAlert, Package, Activity, Pill, Utensils } from 'lucide-react'

export default async function DashboardOverview() {
  const supabase = await createClient()

  const [
    { count: residentCount },
    { count: logCount },
    { count: alertCount },
    { count: inventoryLowCount },
    { count: staffCount },
    { data: recentLogs },
  ] = await Promise.all([
    supabase.from('residents').select('*', { count: 'exact', head: true }),
    supabase.from('daily_logs').select('*', { count: 'exact', head: true }),
    supabase.from('emergency_alerts').select('*', { count: 'exact', head: true }).eq('resolved', false),
    supabase.from('inventory').select('*', { count: 'exact', head: true }).lt('quantity', 5),
    supabase.from('staff').select('*', { count: 'exact', head: true }).eq('is_active', true),
    supabase.from('daily_logs').select('*, residents(name)').order('logged_at', { ascending: false }).limit(5),
  ])

  const stats = [
    { label: 'CENSUS', value: residentCount ?? 0, icon: Users, color: 'text-white' },
    { label: 'LOG ENTRIES', value: logCount ?? 0, icon: ClipboardList, color: 'text-white' },
    { label: 'PERSONNEL', value: staffCount ?? 0, icon: Activity, color: 'text-white' },
    { label: 'ACTIVE ALERTS', value: alertCount ?? 0, icon: ShieldAlert, color: 'text-red-500' },
    { label: 'CRITICAL STOCK', value: inventoryLowCount ?? 0, icon: Package, color: 'text-yellow-500' },
  ]

  const statusColors: Record<string, string> = {
    good: 'text-green-500 bg-green-950 px-2 py-0.5 border border-green-500',
    fair: 'text-yellow-500 bg-yellow-950 px-2 py-0.5 border border-yellow-500',
    poor: 'text-orange-500 bg-orange-950 px-2 py-0.5 border border-orange-500',
    critical: 'text-red-500 bg-red-950 px-2 py-0.5 border border-red-500 animate-pulse',
  }

  return (
    <div className="space-y-8 bg-black">
      <h2 className="text-2xl font-bold tracking-widest uppercase text-white border-b-2 border-zinc-900 pb-4">
        FACILITY OVERVIEW
      </h2>

      {/* Stats Grid */}
      <div className="grid grid-cols-2 md:grid-cols-5 gap-0 border-2 border-zinc-900 border-b-0 space-y-0">
        {stats.map((stat, i) => (
          <div key={stat.label} className="bg-black border-b-2 border-r-2 border-zinc-900 p-6 flex flex-col justify-between items-start last:border-r-0 md:[&:nth-child(5n)]:border-r-0">
            <stat.icon className={`w-8 h-8 mb-4 ${stat.color}`} />
            <p className="text-4xl font-mono text-white tracking-widest">{stat.value}</p>
            <p className="text-[10px] font-bold tracking-widest uppercase text-zinc-500 mt-2">{stat.label}</p>
          </div>
        ))}
      </div>

      {/* Recent Logs */}
      <div>
        <h3 className="text-lg font-bold tracking-widest uppercase text-white border-b-2 border-zinc-900 pb-2 mb-4">
          RECENT LOG ENTRIES
        </h3>
        {recentLogs && recentLogs.length > 0 ? (
          <div className="space-y-0 border-2 border-zinc-900">
            {recentLogs.map((log: any, i: number) => (
              <div key={log.id} className={`bg-black p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between ${i !== 0 ? 'border-t-2 border-zinc-900' : ''}`}>
                <div className="mb-2 sm:mb-0">
                  <p className="text-white font-bold tracking-widest uppercase">{log.residents?.name || 'UNKNOWN'}</p>
                  <p className="text-xs font-mono text-zinc-500">
                    {new Date(log.logged_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }).toUpperCase()}
                  </p>
                </div>
                <div className="flex items-center gap-3">
                  <span className={`text-[10px] font-bold tracking-widest uppercase ${statusColors[log.status] || 'text-zinc-500 border border-zinc-500 px-2 py-0.5'}`}>
                    {log.status}
                  </span>
                  {log.meal_taken && (
                    <span className="flex items-center gap-1 text-[10px] font-bold tracking-widest uppercase text-zinc-400 border border-zinc-800 px-2 py-0.5">
                      <Utensils className="w-3 h-3" /> MEAL
                    </span>
                  )}
                  {log.medication_taken && (
                    <span className="flex items-center gap-1 text-[10px] font-bold tracking-widest uppercase text-zinc-400 border border-zinc-800 px-2 py-0.5">
                      <Pill className="w-3 h-3" /> MEDS
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p className="text-zinc-500 text-sm font-mono uppercase tracking-widest">NO LOG ENTRIES DETECTED.</p>
        )}
      </div>
    </div>
  )
}
