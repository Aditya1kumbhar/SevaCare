'use client'

import { useState, useEffect, use } from 'react'
import { createClient } from '@/lib/supabase/client'
import { useRouter } from 'next/navigation'
import { toast } from 'sonner'
import { Utensils, Pill, Smile, Meh, Frown, Angry, ClipboardList } from 'lucide-react'

const STATUS_OPTIONS = [
  { value: 'good', label: 'OPTIMAL', color: 'bg-green-600 hover:bg-green-500 text-white' },
  { value: 'fair', label: 'FAIR', color: 'bg-yellow-600 hover:bg-yellow-500 text-white' },
  { value: 'poor', label: 'POOR', color: 'bg-orange-600 hover:bg-orange-500 text-white' },
  { value: 'critical', label: 'CRITICAL', color: 'bg-red-600 hover:bg-red-500 text-white animate-pulse' },
]

const MOOD_OPTIONS = [
  { value: 'happy', label: 'STABLE', icon: Smile },
  { value: 'neutral', label: 'NEUTRAL', icon: Meh },
  { value: 'sad', label: 'WITHDRAWN', icon: Frown },
  { value: 'agitated', label: 'AGITATED', icon: Angry },
]

export default function LogStatusPage({ params }: { params: Promise<{ residentId: string }> }) {
  const { residentId } = use(params)
  const [resident, setResident] = useState<any>(null)
  const [status, setStatus] = useState('')
  const [mood, setMood] = useState('')
  const [mealTaken, setMealTaken] = useState(false)
  const [medicationTaken, setMedicationTaken] = useState(false)
  const [notes, setNotes] = useState('')
  const [loading, setLoading] = useState(false)
  const router = useRouter()
  const supabase = createClient()

  useEffect(() => {
    async function fetchResident() {
      const { data } = await supabase
        .from('residents')
        .select('*')
        .eq('id', residentId)
        .single()
      setResident(data)
    }
    fetchResident()
  }, [residentId])

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault()
    if (!status) {
      toast.error('Please select a health status')
      return
    }
    setLoading(true)

    try {
      const res = await fetch('/api/log-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          resident_id: residentId,
          status,
          mood: mood || null,
          meal_taken: mealTaken,
          medication_taken: medicationTaken,
          notes: notes || null,
        }),
      })

      const result = await res.json()

      if (!res.ok) {
        toast.error(result.error || 'Failed to log status')
        setLoading(false)
        return
      }

      toast.success('Status logged!')

      // Redirect back to dashboard


      router.push('/dashboard')
      router.refresh()
    } catch {
      toast.error('Something went wrong')
    } finally {
      setLoading(false)
    }
  }

  if (!resident) {
    return <p className="text-zinc-500 text-center py-16 font-mono text-sm uppercase tracking-widest">RETRIEVING RECORD...</p>
  }

  return (
    <div className="space-y-6 max-w-2xl mx-auto bg-black min-h-screen">
      <div className="border-b-2 border-zinc-900 pb-4 mb-6">
        <h2 className="text-2xl font-bold tracking-widest uppercase text-white flex items-center gap-2">
          <ClipboardList className="w-6 h-6" /> PROTOCOL LOG ENTRY
        </h2>
        <p className="text-zinc-500 font-mono text-xs uppercase tracking-widest mt-2 border-l-2 border-zinc-800 pl-2">
          TARGET: {resident.name} | AGE {resident.age}
          {resident.room_number && ` | RM ${resident.room_number}`}
        </p>
      </div>

      <form onSubmit={handleSubmit} className="space-y-6">
        {/* Health Status */}
        <div className="space-y-2 bg-black border-2 border-zinc-900 p-6">
          <label className="text-[10px] font-bold text-zinc-500 uppercase tracking-widest block mb-4 border-b-2 border-zinc-900 pb-2">
            OVERALL CLINICAL STATUS SUMMARY *
          </label>
          <div className="grid grid-cols-2 gap-0 border-2 border-zinc-800">
            {STATUS_OPTIONS.map((opt) => (
              <button
                key={opt.value}
                type="button"
                onClick={() => setStatus(opt.value)}
                className={`py-6 text-sm font-bold tracking-widest uppercase transition-none border-r border-b border-zinc-800 nth-child(even):border-r-0 last:border-b-0 nth-last-child(2):border-b-0 ${
                  status === opt.value
                    ? opt.color
                    : 'bg-black hover:bg-zinc-900 text-zinc-500'
                }`}
              >
                {opt.label}
              </button>
            ))}
          </div>
        </div>

        {/* Meal & Medication */}
        <div className="grid grid-cols-2 gap-0 border-2 border-zinc-800">
          <button
            type="button"
            onClick={() => setMealTaken(!mealTaken)}
            className={`py-6 text-sm font-bold tracking-widest uppercase transition-none border-r border-zinc-800 flex flex-col items-center gap-2 ${
              mealTaken
                ? 'bg-blue-600 text-white'
                : 'bg-black hover:bg-zinc-900 text-zinc-500'
            }`}
          >
            <Utensils className="w-5 h-5" />
            MEAL {mealTaken ? 'VERIFIED' : 'PENDING'}
          </button>
          <button
            type="button"
            onClick={() => setMedicationTaken(!medicationTaken)}
            className={`py-6 text-sm font-bold tracking-widest uppercase transition-none flex flex-col items-center gap-2 ${
              medicationTaken
                ? 'bg-blue-600 text-white'
                : 'bg-black hover:bg-zinc-900 text-zinc-500'
            }`}
          >
            <Pill className="w-5 h-5" />
            MEDS {medicationTaken ? 'VERIFIED' : 'PENDING'}
          </button>
        </div>

        {/* Mood */}
        <div className="space-y-2 bg-black border-2 border-zinc-900 p-6">
          <label className="text-[10px] font-bold text-zinc-500 uppercase tracking-widest block mb-4 border-b-2 border-zinc-900 pb-2">
            BEHAVIORAL STATE
          </label>
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-0 border-2 border-zinc-800">
            {MOOD_OPTIONS.map((opt) => (
              <button
                key={opt.value}
                type="button"
                onClick={() => setMood(mood === opt.value ? '' : opt.value)}
                className={`py-4 text-[10px] font-bold tracking-widest uppercase transition-none border-r border-b sm:border-b-0 border-zinc-800 last:border-r-0 flex flex-col items-center justify-center gap-1 ${
                  mood === opt.value
                    ? 'bg-blue-600 text-white'
                    : 'bg-black hover:bg-zinc-900 text-zinc-500'
                }`}
              >
                <opt.icon className="w-4 h-4" />
                {opt.label}
              </button>
            ))}
          </div>
        </div>

        {/* Notes */}
        <textarea
          placeholder="ADDITIONAL PROTOCOL NOTES..."
          value={notes}
          onChange={(e) => setNotes(e.target.value)}
          rows={3}
          className="w-full px-4 py-4 text-sm font-mono uppercase bg-black border-2 border-zinc-800 text-white placeholder-zinc-600 focus:outline-none focus:border-blue-500 transition-none resize-none"
        />

        {/* Submit */}
        <div className="flex gap-0 border-2 border-zinc-800 bg-black">
          <button
            type="button"
            onClick={() => router.back()}
            className="w-1/3 py-5 text-sm font-bold tracking-widest uppercase bg-black hover:bg-zinc-900 text-zinc-500 transition-none border-r-2 border-zinc-800"
          >
            ABORT
          </button>
          <button
            type="submit"
            disabled={loading || !status}
            className="w-2/3 py-5 text-sm font-bold tracking-widest uppercase bg-green-600 hover:bg-green-500 text-white disabled:bg-zinc-800 disabled:text-zinc-500 transition-none flex items-center justify-center gap-2"
          >
            {loading ? 'PROCESSING...' : <><ClipboardList className="w-5 h-5"/> LOG STATUS ENTRY</>}
          </button>
        </div>
      </form>
    </div>
  )
}
