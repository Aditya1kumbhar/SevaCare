# ===== Database (Supabase) =====
# Get these from: Supabase Dashboard -> Project Settings -> Database
# Transaction/Pooler connection string (port 6543)
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection string (port 5432) — used by Prisma for migrations
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ===== JWT Configuration =====
JWT_SECRET=your_jwt_secret_key_here_change_in_production_minimum_32_chars
JWT_EXPIRATION=24h

# ===== Firebase Configuration (for push notifications) =====
FIREBASE_PROJECT_ID=sevacare-elderly-care
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@sevacare-elderly-care.iam.gserviceaccount.com

# ===== Frontend (public, safe to expose) =====
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sevacare-elderly-care.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sevacare-elderly-care
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sevacare-elderly-care.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=882411626967
NEXT_PUBLIC_FIREBASE_APP_ID=1:882411626967:web:...
NEXT_PUBLIC_FIREBASE_VAPID_KEY=DUX3FXVJ...
